# LaundryLink - Comprehensive .gitignore

###################
# ENVIRONMENT VARIABLES & SECRETS
###################
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
backend/.env
web/.env
mobile/local.properties

###################
# JAVA/MAVEN (Backend)
###################
backend/target/
backend/*.jar
backend/*.war
backend/*.ear
backend/*.class
backend/.mvn/
backend/mvnw
backend/mvnw.cmd

# Spring Boot
backend/application-*.properties
backend/application-*.yml

# Package Files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# JVM Crash logs
hs_err_pid*
replay_pid*

###################
# NODE.JS/REACT (Web)
###################
web/node_modules/
web/dist/
web/build/
web/.cache/

# Testing
web/coverage/
web/.nyc_output/

# Production
web/build/
web/dist/

# Logs
web/logs/
web/*.log
web/npm-debug.log*
web/yarn-debug.log*
web/yarn-error.log*
web/lerna-debug.log*
web/.pnpm-debug.log*

# Misc
web/.DS_Store
web/.env.local
web/.env.development.local
web/.env.test.local
web/.env.production.local

###################
# KOTLIN/ANDROID (Mobile)
###################
mobile/*.iml
mobile/.gradle/
mobile/.idea/
mobile/local.properties
mobile/build/
mobile/captures/
mobile/.externalNativeBuild/
mobile/.cxx/

# Android Studio
mobile/app/build/
mobile/app/release/
mobile/app/debug/
mobile/.navigation/

# Keystore files
*.jks
*.keystore

# Google Services
mobile/google-services.json

# NDK
mobile/obj/

###################
# NODE MODULES (All)
###################
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

###################
# IDE & EDITORS
###################

# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/
.idea_modules/

# VS Code
.vscode/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Eclipse
.project
.classpath
.settings/
.metadata/
bin/
tmp/
*.tmp
*.bak
*.swp
*~.nib

# NetBeans
nbproject/private/
nbbuild/
nbdist/
.nb-gradle/

# Android Studio
.gradle/
gradle/
gradlew
gradlew.bat
.idea/
*.apk
*.ap_
*.aab

###################
# OPERATING SYSTEMS
###################

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

###################
# LOGS & DATABASES
###################
*.log
*.sql
*.sqlite
*.db
logs/
log/

###################
# BUILD ARTIFACTS
###################
dist/
build/
target/
out/
*.class
*.jar
*.war

###################
# TEMPORARY FILES
###################
*.tmp
*.temp
*.cache
*.bak
*.swp
*.swo
*~

###################
# UPLOADS & USER FILES
###################
uploads/
files/
storage/
qrcodes/

###################
# TESTING
###################
coverage/
.nyc_output/
test-results/
junit/
*.cover
.coverage
.coverage.*
htmlcov/

###################
# DEPENDENCIES
###################
bower_components/
jspm_packages/
vendor/

###################
# MISC
###################
.env.backup
.vercel
.netlify
.firebase/
.cache/
.parcel-cache/
.next/
.nuxt/
.vuepress/dist/

###################
# SUPABASE
###################
.supabase/

###################
